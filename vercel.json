{
  "version": 2,
  "builds": [
    {
      "src": "uploads/**",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/app.js"
    }
  ]
}
